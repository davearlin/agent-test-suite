# Cloud Run production nginx configuration
# 
# This template is processed by envsubst at container startup.
# Only $PORT and $BACKEND_SERVICE_URL are substituted; all nginx
# variables ($uri, $host, $proxy_host, etc.) are preserved.
#
# Environment variables:
#   $PORT                - Port to listen on (set by Cloud Run, default 8080)
#   $BACKEND_SERVICE_URL - Backend Cloud Run internal URL
#                          (e.g., https://dialogflow-tester-backend-dev-xxx.us-central1.run.app)

server {
    listen $PORT;
    server_name _;
    root /usr/share/nginx/html;
    index index.html index.htm;

    # Google internal metadata DNS — works inside VPC-connected Cloud Run containers
    # (8.8.8.8 is unreachable when egress=all-traffic routes through VPC connector)
    resolver 169.254.169.254 valid=300s;
    resolver_timeout 5s;

    # Allow larger file uploads (100MB)
    client_max_body_size 100M;

    # Gzip compression for static assets
    gzip on;
    gzip_types text/plain text/css application/json application/javascript text/xml application/xml text/javascript image/svg+xml;
    gzip_min_length 256;

    # Handle client-side routing (React SPA)
    location / {
        try_files $uri $uri/ /index.html;

        # Cache static assets aggressively (Vite adds content hashes)
        location ~* \.(js|css|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot)$ {
            expires 1y;
            add_header Cache-Control "public, immutable";
        }
    }

    # Reverse proxy API requests to backend Cloud Run service (internal ingress)
    location /api/ {
        # Use a variable so nginx resolves DNS at request time, not startup
        set $backend "$BACKEND_SERVICE_URL";
        proxy_pass $backend;
        proxy_http_version 1.1;
        proxy_ssl_server_name on;
        proxy_set_header Host $proxy_host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
        proxy_cache_bypass $http_upgrade;

        # Allow larger file uploads through proxy
        client_max_body_size 100M;

        # Increase timeouts for long-running evaluation requests
        proxy_connect_timeout 300s;
        proxy_send_timeout 300s;
        proxy_read_timeout 300s;
    }

    # WebSocket proxy to backend
    location /ws/ {
        set $backend_ws "$BACKEND_SERVICE_URL";
        proxy_pass $backend_ws;
        proxy_http_version 1.1;
        proxy_ssl_server_name on;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $proxy_host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
    }

    # Health check endpoint for Cloud Run
    location /health {
        access_log off;
        return 200 'healthy';
        add_header Content-Type text/plain;
    }
}
